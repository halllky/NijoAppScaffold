{
  "name": "haldoc-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "demo/100_チャットアプリ/client",
    "Document",
    "Nijo.NewProjectTemplate/client",
    "Nijo.ApplicationTemplate.Ver1/react/package_nijo-client-sample",
    "Nijo.ApplicationTemplate.Ver1/react/package_schema-editor",
    "Nijo.ApplicationTemplate.Ver1/react/package_ui-components",
    "Nijo.ApplicationTemplate.Ver1/react/package_ui-components-debug"
  ],
  "scripts": {
    "dev:chat-app": "npm run dev --workspace=demo/100_チャットアプリ/client",
    "dev:docs": "npm run docs:dev --workspace=Document",
    "dev:new-project-template": "npm run dev --workspace=Nijo.NewProjectTemplate/client",
    "dev:nijo-client-sample": "npm run dev --workspace=Nijo.ApplicationTemplate.Ver1/react/package_nijo-client-sample",
    "dev:schema-editor": "npm run dev --workspace=Nijo.ApplicationTemplate.Ver1/react/package_schema-editor",
    "dev:ui-components": "npm run dev --workspace=Nijo.ApplicationTemplate.Ver1/react/package_ui-components",
    "dev:ui-components-debug": "npm run dev --workspace=Nijo.ApplicationTemplate.Ver1/react/package_ui-components-debug",
    "build:chat-app": "npm run build --workspace=demo/100_チャットアプリ/client",
    "build:docs": "npm run docs:build --workspace=Document",
    "build:new-project-template": "npm run build --workspace=Nijo.NewProjectTemplate/client",
    "build:nijo-client-sample": "npm run build --workspace=Nijo.ApplicationTemplate.Ver1/react/package_nijo-client-sample",
    "build:schema-editor": "npm run build --workspace=Nijo.ApplicationTemplate.Ver1/react/package_schema-editor",
    "build:ui-components": "npm run build --workspace=Nijo.ApplicationTemplate.Ver1/react/package_ui-components",
    "build:ui-components-debug": "npm run build --workspace=Nijo.ApplicationTemplate.Ver1/react/package_ui-components-debug",
    "test:all": "npm run test --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "tsc:all": "npm run tsc --workspaces --if-present"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.1.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.6",
    "allotment": "^1.20.4",
    "cytoscape": "^3.32.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-klay": "^3.1.4",
    "cytoscape-navigator": "^2.0.2",
    "cytoscape-node-html-label": "^1.2.2",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.6.0",
    "linkify-react": "^4.3.1",
    "linkifyjs": "^4.3.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.55.0",
    "react-mentions": "^4.4.10",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^7.4.1",
    "react-use-event-hook": "^0.9.6",
    "tailwindcss": "^4.1.4",
    "uuidjs": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/react-mentions": "^4.4.1",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "mermaid": "^11.9.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.6",
    "vite-plugin-singlefile": "^2.2.0",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.2.4"
  }
}