{
  "name": "haldoc-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "demo/000_基本的なDataModelの例/client",
    "demo/101_販売管理システム/client",
    "demo/200_複雑なパターン/client",
    "Document",
    "Nijo.NewProjectTemplate/client",
    "Nijo.GuiClient/package_schema-editor-v1",
    "Nijo.GuiClient/package_ui-components",
    "Nijo.GuiClient/package_ui-components-debug"
  ],
  "scripts": {
    "dev:docs": "npm run start --workspace=Document",
    "dev:new-project-template": "npm run dev --workspace=Nijo.NewProjectTemplate/client",
    "dev:ui-components": "npm run dev --workspace=Nijo.GuiClient/package_ui-components",
    "dev:ui-components-debug": "npm run dev --workspace=Nijo.GuiClient/package_ui-components-debug",
    "build:docs": "npm run build --workspace=Document",
    "build:new-project-template": "npm run build --workspace=Nijo.NewProjectTemplate/client",
    "build:schema-editor": "npm run build --workspace=Nijo.GuiClient/package_schema-editor-v1",
    "build:ui-components": "npm run build --workspace=Nijo.GuiClient/package_ui-components",
    "build:ui-components-debug": "npm run build --workspace=Nijo.GuiClient/package_ui-components-debug",
    "test:all": "npm run test --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "tsc:all": "npm run tsc --workspaces --if-present"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/react": "^3.0.0",
    "@tailwindcss/vite": "^4.1.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.6",
    "allotment": "^1.20.4",
    "clsx": "^2.0.0",
    "cytoscape": "^3.32.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-klay": "^3.1.4",
    "cytoscape-navigator": "^2.0.2",
    "cytoscape-node-html-label": "^1.2.2",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.6.0",
    "linkify-react": "^4.3.1",
    "linkifyjs": "^4.3.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.55.0",
    "react-hotkeys-hook": "^5.1.0",
    "react-mentions": "^4.4.10",
    "react-router-dom": "^7.4.1",
    "react-use-event-hook": "^0.9.6",
    "tailwindcss": "^4.1.4",
    "uuidjs": "^5.1.0"
