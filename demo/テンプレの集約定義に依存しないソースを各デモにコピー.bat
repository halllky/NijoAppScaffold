chcp 65001 
@echo off 
 
set "SOURCE_ROOT=%~dp0..\Nijo.ApplicationTemplate.Ver1" 
 
@rem デモフォルダをループし全デモフォルダに対してコピー処理を行う 
for /d %%d in ("%~dp0\*") do (
    set "TARGET_ROOT=%%d" 
    call :COPY_REACT 
    call :COPY_CORE 
    call :COPY_CORE_AUTOGENERATED 
    call :COPY_WEBAPI 
) 
@echo コピー完了しました 
exit /b 
 
@rem **************************************** 
@rem コピー実行 
@rem コピー元のファイルでコピー先のフォルダ構造ごと完全に洗い替える 
@rem コピー先に同じ名前のファイルがある場合は上書きする 
@rem コピー先に同じ名前のファイルが無い場合はコピー先の当該ファイルを削除する 
 
:COPY_REACT 
@rem React 
set "SOURCE_DIR=%SOURCE_ROOT%\react\package_ui-components" 
set "TARGET_DIR=%TARGET_ROOT%\react\package_ui-components" 
set "EXCLUDE_DIRS=node_modules dist" 
set "EXCLUDE_FILES=" 
robocopy "%SOURCE_DIR%" "%TARGET_DIR%" /MIR /XA:SH /XD %EXCLUDE_DIRS% /XF %EXCLUDE_FILES% 
exit /b 
 
:COPY_CORE 
@rem Core 
set "SOURCE_DIR=%SOURCE_ROOT%\Core" 
set "TARGET_DIR=%TARGET_ROOT%\Core" 
set "EXCLUDE_DIRS=.vs bin obj OverridedApplicationConfigure.cs OverridedApplicationService.cs" 
set "EXCLUDE_FILES=" 
robocopy "%SOURCE_DIR%" "%TARGET_DIR%" /MIR /XA:SH /XD %EXCLUDE_DIRS% /XF %EXCLUDE_FILES% 
exit /b 
 
:COPY_CORE_AUTOGENERATED 
@rem Core.AutoGenerated 
set "SOURCE_DIR=%SOURCE_ROOT%\Core.AutoGenerated" 
set "TARGET_DIR=%TARGET_ROOT%\Core.AutoGenerated" 
set "EXCLUDE_DIRS=__AutoGenerated MigrationsScript PartialClasses.cs .vs bin obj" 
set "EXCLUDE_FILES=" 
robocopy "%SOURCE_DIR%" "%TARGET_DIR%" /MIR /XA:SH /XD %EXCLUDE_DIRS% /XF %EXCLUDE_FILES% 
exit /b 
 
:COPY_WEBAPI 
@rem WebApi 
set "SOURCE_DIR=%SOURCE_ROOT%\WebApi" 
set "TARGET_DIR=%TARGET_ROOT%\WebApi" 
set "EXCLUDE_DIRS=__AutoGenerated .vs bin obj" 
set "EXCLUDE_FILES=" 
robocopy "%SOURCE_DIR%" "%TARGET_DIR%" /MIR /XA:SH /XD %EXCLUDE_DIRS% /XF %EXCLUDE_FILES% 
exit /b 
