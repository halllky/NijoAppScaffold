@echo off

set "PROJECT_ROOT=%1"
if "%PROJECT_ROOT%"=="" (
  set /p "PROJECT_ROOT=プロジェクトルートパス: "
)

set "OUT_DIR=%2"
if "%OUT_DIR%"=="" (
  set /p "OUT_DIR=出力先フォルダ名: "
)

if "%PROJECT_ROOT%"=="" (
  echo プロジェクトルートパスが指定されていません。
  exit /b
)

if "%OUT_DIR%"=="" (
  echo 出力先フォルダ名が指定されていません。
  exit /b
)

set "OUT_DIR_FULLPATH=%~dp0..\temp_ソース現新比較用\%OUT_DIR%"

mkdir %OUT_DIR_FULLPATH%

xcopy /I /S /E /Y "%PROJECT_ROOT%\Core.AutoGenerated\__AutoGenerated" %OUT_DIR_FULLPATH%\CORE    >nul 
xcopy /I /S /E /Y "%PROJECT_ROOT%\WebApi\__AutoGenerated"             %OUT_DIR_FULLPATH%\WEBAPI  >nul 
xcopy /I /S /E /Y "%PROJECT_ROOT%\client\src\__autoGenerated"         %OUT_DIR_FULLPATH%\CLIENT  >nul 
xcopy /I /S /E /Y "%PROJECT_ROOT%\UnitTest\__AutoGenerated"           %OUT_DIR_FULLPATH%\TEST    >nul 

explorer "%~dp0..\temp_ソース現新比較用"
